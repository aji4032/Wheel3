<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="JMeter Test Suite">
    <!-- Path to the JMeter .jmx test plan to run -->
    <parameter name="jmxFile" value="src/test/resources/temp-test.jmx"/>
    
    <test name="JMeter Performance Tests">
        <classes>
            <class name="tools.JMeterTest">
                <methods>
                    <!-- Executing the parameterized method only, as XML suites explicitly define parameters -->
                    <include name="runJmxTestFromParameter"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
